<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Topper Frnd AI</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f0f2f5; margin: 0; padding: 20px; text-align: center; }
        .dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 1000px; margin: auto; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); transition: 0.3s; cursor: pointer; }
        .card:hover { transform: translateY(-5px); border: 2px solid #007bff; }
        h1 { color: #1a73e8; }
        .icon { font-size: 40px; margin-bottom: 10px; }
    </style>
</head>
<body>
    <h1>🎓 Topper Frnd AI</h1>
    <p>Your Personalized Exam Prep Assistant</p>
    
    <div class="dashboard">
        <div class="card"> <div class="icon">🤖</div> <h3>AI Study Coach</h3> </div>
        <div class="card"> <div class="icon">💻</div> <h3>Code Mentor</h3> </div>
        <div class="card"> <div class="icon">📝</div> <h3>Smart Notes</h3> </div>
        <div class="card"> <div class="icon">🎯</div> <h3>Quiz Engine</h3> </div>
        <div class="card"> <div class="icon">📅</div> <h3>Smart Planner</h3> </div>
        <div class="card"> <div class="icon">⚡</div> <h3>Lightning Practice</h3> </div>
    </div>
</body>
</html>
